{
  "name": "station-colony-sim",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:sim": "tsc -p tsconfig.simtest.json && node tools/write-simtest-package.cjs && node .tmp/sim-tests/tools/sim-tests.js",
    "test:harness": "playwright test",
    "test:harness:update-snapshots": "playwright test --update-snapshots",
    "perf:sim": "tsc -p tsconfig.simtest.json && node tools/write-simtest-package.cjs && node .tmp/sim-tests/tools/sim-perf.js",
    "sprites:curated:bootstrap": "node tools/sprites/bootstrap-curated.mjs",
    "sprites:generate:test": "node tools/sprites/generate-nanobanana.mjs --profile test",
    "sprites:generate:v1": "node tools/sprites/generate-nanobanana.mjs --profile v1",
    "sprites:generate:floors-walls": "node tools/sprites/generate-nanobanana.mjs --profile floors-walls",
    "sprites:generate:agents": "node tools/sprites/generate-nanobanana.mjs --profile agents",
    "sprites:generate:tiles-full": "node tools/sprites/generate-nanobanana.mjs --profile tiles-full",
    "sprites:regenerate:test": "node tools/sprites/generate-nanobanana.mjs --profile test --overwrite",
    "sprites:regenerate:v1": "node tools/sprites/generate-nanobanana.mjs --profile v1 --overwrite",
    "sprites:regenerate:floors-walls": "node tools/sprites/generate-nanobanana.mjs --profile floors-walls --overwrite",
    "sprites:regenerate:agents": "node tools/sprites/generate-nanobanana.mjs --profile agents --overwrite",
    "sprites:regenerate:tiles-full": "node tools/sprites/generate-nanobanana.mjs --profile tiles-full --overwrite",
    "sprites:retry:test": "node tools/sprites/retry-sprites.mjs --profile test",
    "sprites:retry:v1": "node tools/sprites/retry-sprites.mjs --profile v1",
    "sprites:retry:floors-walls": "node tools/sprites/retry-sprites.mjs --profile floors-walls",
    "sprites:retry:floors-walls:activate": "node tools/sprites/retry-sprites.mjs --profile floors-walls --activate",
    "sprites:retry:agents": "node tools/sprites/retry-sprites.mjs --profile agents",
    "sprites:retry:tiles-full": "node tools/sprites/retry-sprites.mjs --profile tiles-full",
    "sprites:process": "node tools/sprites/postprocess-raw.mjs --profile v1 --overwrite",
    "sprites:process:floors-walls": "node tools/sprites/postprocess-raw.mjs --profile floors-walls --overwrite",
    "sprites:process:agents": "node tools/sprites/postprocess-raw.mjs --profile agents --overwrite",
    "sprites:process:tiles-full": "node tools/sprites/postprocess-raw.mjs --profile tiles-full --overwrite",
    "sprites:pack": "node tools/sprites/pack-atlas.mjs --profile v1",
    "sprites:pack:test": "node tools/sprites/pack-atlas.mjs --profile test",
    "sprites:pack:floors-walls": "node tools/sprites/pack-atlas.mjs --profile floors-walls",
    "sprites:pack:floors-walls:activate": "node tools/sprites/pack-atlas.mjs --profile floors-walls --activate",
    "sprites:pack:agents": "node tools/sprites/pack-atlas.mjs --profile agents",
    "sprites:pack:tiles-full": "node tools/sprites/pack-atlas.mjs --profile tiles-full",
    "sprites:validate:test": "node tools/sprites/validate-atlas.mjs --profile test",
    "sprites:validate:v1": "node tools/sprites/validate-atlas.mjs --profile v1",
    "sprites:validate:floors-walls": "node tools/sprites/validate-atlas.mjs --profile floors-walls",
    "sprites:validate:agents": "node tools/sprites/validate-atlas.mjs --profile agents",
    "sprites:validate:tiles-full": "node tools/sprites/validate-atlas.mjs --profile tiles-full",
    "sprites:edit:export": "node tools/sprites/export-edit-sheet.mjs --profile v1",
    "sprites:edit:import": "node tools/sprites/import-edit-sheet.mjs --profile v1",
    "sprites:edit:apply": "npm run sprites:edit:import && npm run sprites:pack && npm run sprites:validate:v1",
    "sprites:edit:apply:activate": "npm run sprites:edit:import && node tools/sprites/pack-atlas.mjs --profile v1 --activate && npm run sprites:validate:v1",
    "sprites:edit:export:tiles": "node tools/sprites/export-edit-sheet.mjs --profile tiles-full",
    "sprites:edit:import:tiles": "node tools/sprites/import-edit-sheet.mjs --profile tiles-full",
    "sprites:edit:apply:tiles": "npm run sprites:edit:import:tiles && npm run sprites:pack && npm run sprites:validate:v1",
    "sprites:edit:apply:tiles:activate": "npm run sprites:edit:import:tiles && node tools/sprites/pack-atlas.mjs --profile v1 --activate && npm run sprites:validate:v1",
    "sprites:scene:export": "node tools/sprites/export-save-scene.mjs",
    "sprites:scene:crop": "node tools/sprites/crop-save-scene.mjs",
    "sprites:scene:guide": "node tools/sprites/export-save-crop-guide.mjs",
    "sprites:scene:stylize": "node tools/sprites/stylize-save-scene.mjs",
    "sprites:atlas:guide": "node tools/sprites/export-atlas-guide.mjs",
    "sprites:atlas:worksheet": "node tools/sprites/export-atlas-worksheet.mjs",
    "sprites:atlas:worksheet:import": "node tools/sprites/import-atlas-worksheet.mjs",
    "sprites:atlas:worksheet:migrate-old": "node tools/sprites/migrate-old-worksheet.mjs",
    "sprites:build:test": "npm run sprites:generate:test && node tools/sprites/postprocess-raw.mjs --profile test --overwrite && node tools/sprites/pack-atlas.mjs --profile test --source processed && npm run sprites:validate:test",
    "sprites:build:v1": "npm run sprites:generate:v1 && npm run sprites:process && node tools/sprites/pack-atlas.mjs --profile v1 --source processed && npm run sprites:validate:v1",
    "sprites:build:floors-walls": "npm run sprites:generate:floors-walls && npm run sprites:process:floors-walls && node tools/sprites/pack-atlas.mjs --profile floors-walls --source processed && npm run sprites:validate:floors-walls",
    "sprites:build:floors-walls:activate": "npm run sprites:generate:floors-walls && npm run sprites:process:floors-walls && node tools/sprites/pack-atlas.mjs --profile floors-walls --source processed --activate && npm run sprites:validate:floors-walls",
    "sprites:build:agents": "npm run sprites:generate:agents && npm run sprites:process:agents && node tools/sprites/pack-atlas.mjs --profile agents --source processed && npm run sprites:validate:agents",
    "sprites:build:tiles-full": "npm run sprites:generate:tiles-full && npm run sprites:process:tiles-full && node tools/sprites/pack-atlas.mjs --profile tiles-full --source processed && npm run sprites:validate:tiles-full"
  },
  "devDependencies": {
    "@google/genai": "^1.30.0",
    "@playwright/test": "^1.44.0",
    "dotenv": "^16.5.0",
    "sharp": "^0.34.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "yaml": "^2.8.2"
  }
}
