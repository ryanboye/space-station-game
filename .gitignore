# Dependencies
node_modules/
.tmp

# Build output
dist/

# Sprite pipeline: post-processed outputs are regenerated from raw/ by
# postprocess-raw.mjs every sprite rebuild, so they're pure noise in
# PR diffs. Raws stay TRACKED — generate-nanobanana.mjs uses raw/ as a
# skip-cache (a raw on disk means "don't re-burn a Gemini call for
# this key"), and keeping raw history lets us bisect regressions back
# to the exact generation that shipped.
tools/sprites/out/processed/
tools/sprites/out/processed-pixellab/

# qa-review.mjs (gpt-image-1 v2 pipeline): staging is raw generator output
# awaiting review; approved/rejected are the reviewer's sorted buckets.
# None of these are build inputs in the legacy pipeline, and the v2 pack
# path will regenerate the atlas from approved/, so checking them in
# just adds diff noise.
tools/sprites/out/staging/
tools/sprites/out/approved/
tools/sprites/out/rejected/

# Local env files
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/editor files
.DS_Store
.vscode/
.idea/

# Playwright
test-results/
playwright-report/

# Harness run output (generated, not committed)
/tmp/harness-runs/
